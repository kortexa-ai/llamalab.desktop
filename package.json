{
	"name": "llamalab-desktop",
	"version": "0.1.0",
	"description": "Llama Lab Research Center — local research IDE",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"build:stable": "vite build && electrobun build --env=stable"
	},
	"dependencies": {
		"electrobun": "1.14.4",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"@xyflow/react": "^12.6.4",
		"d3-force": "^3.0.0",
		"@phosphor-icons/react": "^2.1.7",
		"@xterm/xterm": "^5.5.0",
		"@xterm/addon-fit": "^0.10.0",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"clsx": "^2.1.1",
		"tailwind-merge": "^2.6.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@types/d3-force": "^3.0.10",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
