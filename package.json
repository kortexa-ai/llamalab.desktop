{
	"name": "llamalab-desktop",
	"version": "0.1.0",
	"description": "Llama Lab Research Center — local research IDE",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"build:stable": "vite build && electrobun build --env=stable"
	},
	"dependencies": {
		"@phosphor-icons/react": "^2.1.10",
		"@tailwindcss/postcss": "^4.2.1",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"@xyflow/react": "^12.10.1",
		"clsx": "^2.1.1",
		"d3-force": "^3.0.0",
		"electrobun": "1.15.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/d3-force": "^3.0.10",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^9.2.1",
		"npm-check-updates": "^19.6.3",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.0"
	}
}
